# Inphora EntrepriseOS - Environment Variables Example
# Copy this file to .env and fill in the values

# API Configuration
PROJECT_NAME="Inphora EntrepriseOS"
API_V1_STR="/api/v1"
ENVIRONMENT="development" # development | production

# Security
# Generate a secret key using: openssl rand -hex 32
SECRET_KEY="generate_with_openssl_rand_hex_32"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL)
POSTGRES_SERVER="db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="entreprise_os"

# Redis (for Celery and Caching)
REDIS_URL="redis://redis:6379/0"

# CORS
# Comma-separated list of origins
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8000"

# Seed Admin Credentials (used by seed.py)
SEED_ADMIN_EMAIL="admin@inphora.com"
SEED_ADMIN_PASSWORD="admin123"
